<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      styleClass="creation-root" spacing="0" prefHeight="1080.0" prefWidth="1920.0">

    <!-- Header -->
    <VBox alignment="CENTER" spacing="6">
        <padding><Insets top="20" bottom="14" left="40" right="40"/></padding>
        <HBox alignment="CENTER" spacing="18">
            <Label text="⚔" style="-fx-font-size: 32px; -fx-text-fill: #6B0000; -fx-effect: dropshadow(gaussian, rgba(212,175,55,0.55), 8, 0, 0, 0);"/>
            <Label text="Codex &amp; Spielregeln" styleClass="section-title" style="-fx-font-size: 34px;"/>
            <Label text="⚔" style="-fx-font-size: 32px; -fx-text-fill: #6B0000; -fx-effect: dropshadow(gaussian, rgba(212,175,55,0.55), 8, 0, 0, 0); -fx-rotate: 180;"/>
        </HBox>
        <Label text="Lies die Lehren und lerne die Regeln des Abenteuers" styleClass="section-subtitle"/>
    </VBox>

    <!-- SplitPane for TreeView and Content -->
    <SplitPane dividerPositions="0.25" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-padding: 0 40 10 40; -fx-background-insets: 0; -fx-box-border: transparent;">
        <!-- Left Side: Tree Navigation -->
        <VBox spacing="8" style="-fx-background-color: transparent;">
            <TreeView fx:id="rulesTree" VBox.vgrow="ALWAYS" styleClass="rules-tree"/>
        </VBox>

        <!-- Right Side: Scrollable detailed reader content -->
        <ScrollPane fitToWidth="true" styleClass="rules-scroll-pane" style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox fx:id="contentPane" spacing="16" styleClass="rules-content-pane">
                <padding><Insets top="20" bottom="20" left="30" right="30"/></padding>
            </VBox>
        </ScrollPane>
    </SplitPane>

    <!-- Bottom navigation -->
    <HBox alignment="CENTER" spacing="40">
        <padding><Insets top="10" bottom="20" left="40" right="40"/></padding>
        <Button fx:id="btnBack" text="◀ Zurück" onAction="#handleBack" styleClass="nav-button-back" prefWidth="160" prefHeight="42"/>
    </HBox>
</VBox>
