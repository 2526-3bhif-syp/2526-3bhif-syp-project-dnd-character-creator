<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.Region?>

<VBox alignment="CENTER" spacing="10.0" style="-fx-border-color: #666666; -fx-border-width: 2; -fx-padding: 15; -fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 10, 0, 0, 0); -fx-min-width: 200; -fx-min-height: 250;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <!-- Place a Region as background behind ImageView to make it visible -->
    <VBox alignment="CENTER" style="-fx-background-color: #eeeeee; -fx-min-height: 150; -fx-min-width: 120;">
        <ImageView fx:id="imageView" fitHeight="150.0" fitWidth="120.0" pickOnBounds="true" preserveRatio="true" />
    </VBox>
    
    <Label fx:id="nameLabel" style="-fx-font-weight: bold; -fx-font-size: 18; -fx-text-fill: black;" text="Wait for Data..." />
    
    <GridPane hgap="10" vgap="5" alignment="CENTER">
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="40.0" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="20.0" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="40.0" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="20.0" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
        </rowConstraints>
        <children>
            <Label text="STR:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #333333;" />
            <Label fx:id="strLabel" style="-fx-font-weight: bold; -fx-text-fill: black;" text="?" GridPane.columnIndex="1" GridPane.rowIndex="0" />
            
            <Label text="DEX:" GridPane.columnIndex="2" GridPane.rowIndex="0" style="-fx-text-fill: #333333;" />
            <Label fx:id="dexLabel" style="-fx-font-weight: bold; -fx-text-fill: black;" text="?" GridPane.columnIndex="3" GridPane.rowIndex="0" />
            
            <Label text="CON:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #333333;" />
            <Label fx:id="conLabel" style="-fx-font-weight: bold; -fx-text-fill: black;" text="?" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            
            <Label text="INT:" GridPane.columnIndex="2" GridPane.rowIndex="1" style="-fx-text-fill: #333333;" />
            <Label fx:id="intLabel" style="-fx-font-weight: bold; -fx-text-fill: black;" text="?" GridPane.columnIndex="3" GridPane.rowIndex="1" />
            
            <Label text="WIS:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #333333;" />
            <Label fx:id="wisLabel" style="-fx-font-weight: bold; -fx-text-fill: black;" text="?" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            
            <Label text="CHA:" GridPane.columnIndex="2" GridPane.rowIndex="2" style="-fx-text-fill: #333333;" />
            <Label fx:id="chaLabel" style="-fx-font-weight: bold; -fx-text-fill: black;" text="?" GridPane.columnIndex="3" GridPane.rowIndex="2" />
        </children>
    </GridPane>
</VBox>
