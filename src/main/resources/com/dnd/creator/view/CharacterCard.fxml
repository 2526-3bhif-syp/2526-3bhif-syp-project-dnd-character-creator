<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           style="-fx-min-width: 252; -fx-max-width: 252;">

    <!-- ══════════════════════════════════════
         MAIN CARD BODY
         ══════════════════════════════════════ -->
    <VBox fx:id="cardRoot" spacing="0"
          style="-fx-min-width: 252; -fx-max-width: 252; -fx-min-height: 395;
                 -fx-background-color: #FDF5E6;
                 -fx-border-color: #FFD700 #B8960C #B8960C #FFD700;
                 -fx-border-width: 4;
                 -fx-background-radius: 10; -fx-border-radius: 10;
                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.75), 16, 0, 4, 6);">

        <!-- ── HEADER: Name + Hit Die ── -->
        <HBox fx:id="headerBox" alignment="CENTER_LEFT" spacing="4"
              style="-fx-padding: 8 10 8 10; -fx-background-radius: 6 6 0 0;
                     -fx-background-color: linear-gradient(to right, #8B0000, #C0392B);">
            <Label fx:id="nameLabel" text="Character Name" maxWidth="160" wrapText="true"
                   style="-fx-font-weight: bold; -fx-font-size: 14; -fx-text-fill: white;
                          -fx-font-family: 'Serif';
                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.95), 3, 0, 1, 1);"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="hpLabel" text="d8"
                   style="-fx-background-color: rgba(0,0,0,0.45); -fx-background-radius: 4;
                          -fx-font-weight: bold; -fx-font-size: 11; -fx-text-fill: #FFD700;
                          -fx-font-family: 'Serif'; -fx-padding: 2 5 2 5;"/>
        </HBox>

        <!-- ── STARS STRIP ── -->
        <HBox alignment="CENTER_RIGHT"
              style="-fx-padding: 3 10 3 10; -fx-background-color: #0C0400;">
            <Label fx:id="starsLabel" text="★★★★"
                   style="-fx-text-fill: #FFD700; -fx-font-size: 13;
                          -fx-effect: dropshadow(gaussian, rgba(255,200,0,0.95), 6, 0.2, 0, 0);"/>
        </HBox>

        <!-- ── PORTRAIT ── -->
        <StackPane style="-fx-padding: 5 7 5 7; -fx-background-color: #0C0400;">
            <VBox style="-fx-border-color: #D4AF37 #FFD700 #B8960C #D4AF37; -fx-border-width: 2;
                         -fx-background-color: #BCA882;
                         -fx-effect: innershadow(gaussian, rgba(0,0,0,0.55), 8, 0, 0, 2);">
                <ImageView fx:id="imageView" fitHeight="148" fitWidth="214"
                           preserveRatio="false" pickOnBounds="true"/>
            </VBox>
        </StackPane>

        <!-- ── TYPE BADGES: Race + Class ── -->
        <HBox alignment="CENTER" spacing="8"
              style="-fx-padding: 5 10 5 10; -fx-background-color: #180900;">
            <Label fx:id="raceLabel" text="Human"
                   style="-fx-background-color: #321400; -fx-text-fill: #FFD700;
                          -fx-font-size: 10; -fx-font-weight: bold;
                          -fx-padding: 2 9 2 9; -fx-background-radius: 10;
                          -fx-border-color: #B8960C; -fx-border-radius: 10; -fx-border-width: 1;"/>
            <Label fx:id="classLabel" text="Fighter"
                   style="-fx-background-color: #6A0000; -fx-text-fill: #FFEEAA;
                          -fx-font-size: 10; -fx-font-weight: bold;
                          -fx-padding: 2 9 2 9; -fx-background-radius: 10;
                          -fx-border-color: #FF9090; -fx-border-radius: 10; -fx-border-width: 1;"/>
        </HBox>

        <!-- ── STATS SECTION ── -->
        <VBox spacing="3" VBox.vgrow="ALWAYS"
              style="-fx-padding: 7 12 7 12; -fx-background-color: #FDF0D0;
                     -fx-border-color: #D4AF37 transparent transparent transparent;
                     -fx-border-width: 1;">
            <GridPane hgap="4" vgap="4" alignment="CENTER">
                <columnConstraints>
                    <ColumnConstraints minWidth="46" halignment="RIGHT"/>
                    <ColumnConstraints minWidth="32" halignment="CENTER"/>
                    <ColumnConstraints minWidth="46" halignment="RIGHT"/>
                    <ColumnConstraints minWidth="32" halignment="CENTER"/>
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints minHeight="22"/>
                    <RowConstraints minHeight="22"/>
                    <RowConstraints minHeight="22"/>
                </rowConstraints>
                <children>
                    <Label text="STR" GridPane.columnIndex="0" GridPane.rowIndex="0"
                           style="-fx-text-fill: #6B0000; -fx-font-weight: bold; -fx-font-size: 11;"/>
                    <Label fx:id="strLabel" text="10" GridPane.columnIndex="1" GridPane.rowIndex="0"
                           style="-fx-background-color: #8B0000; -fx-text-fill: white;
                                  -fx-font-weight: bold; -fx-font-size: 11;
                                  -fx-background-radius: 3; -fx-padding: 1 4 1 4;"/>

                    <Label text="DEX" GridPane.columnIndex="2" GridPane.rowIndex="0"
                           style="-fx-text-fill: #6B0000; -fx-font-weight: bold; -fx-font-size: 11;"/>
                    <Label fx:id="dexLabel" text="10" GridPane.columnIndex="3" GridPane.rowIndex="0"
                           style="-fx-background-color: #8B0000; -fx-text-fill: white;
                                  -fx-font-weight: bold; -fx-font-size: 11;
                                  -fx-background-radius: 3; -fx-padding: 1 4 1 4;"/>

                    <Label text="CON" GridPane.columnIndex="0" GridPane.rowIndex="1"
                           style="-fx-text-fill: #6B0000; -fx-font-weight: bold; -fx-font-size: 11;"/>
                    <Label fx:id="conLabel" text="10" GridPane.columnIndex="1" GridPane.rowIndex="1"
                           style="-fx-background-color: #8B0000; -fx-text-fill: white;
                                  -fx-font-weight: bold; -fx-font-size: 11;
                                  -fx-background-radius: 3; -fx-padding: 1 4 1 4;"/>

                    <Label text="INT" GridPane.columnIndex="2" GridPane.rowIndex="1"
                           style="-fx-text-fill: #6B0000; -fx-font-weight: bold; -fx-font-size: 11;"/>
                    <Label fx:id="intLabel" text="10" GridPane.columnIndex="3" GridPane.rowIndex="1"
                           style="-fx-background-color: #8B0000; -fx-text-fill: white;
                                  -fx-font-weight: bold; -fx-font-size: 11;
                                  -fx-background-radius: 3; -fx-padding: 1 4 1 4;"/>

                    <Label text="WIS" GridPane.columnIndex="0" GridPane.rowIndex="2"
                           style="-fx-text-fill: #6B0000; -fx-font-weight: bold; -fx-font-size: 11;"/>
                    <Label fx:id="wisLabel" text="10" GridPane.columnIndex="1" GridPane.rowIndex="2"
                           style="-fx-background-color: #8B0000; -fx-text-fill: white;
                                  -fx-font-weight: bold; -fx-font-size: 11;
                                  -fx-background-radius: 3; -fx-padding: 1 4 1 4;"/>

                    <Label text="CHA" GridPane.columnIndex="2" GridPane.rowIndex="2"
                           style="-fx-text-fill: #6B0000; -fx-font-weight: bold; -fx-font-size: 11;"/>
                    <Label fx:id="chaLabel" text="10" GridPane.columnIndex="3" GridPane.rowIndex="2"
                           style="-fx-background-color: #8B0000; -fx-text-fill: white;
                                  -fx-font-weight: bold; -fx-font-size: 11;
                                  -fx-background-radius: 3; -fx-padding: 1 4 1 4;"/>
                </children>
            </GridPane>
        </VBox>

        <!-- ── FLAVOR TEXT FOOTER ── -->
        <Label fx:id="bgLabel" text="Unknown Background" wrapText="true"
               maxWidth="242" alignment="CENTER"
               style="-fx-font-style: italic; -fx-font-size: 10; -fx-text-fill: #4A2E0A;
                      -fx-padding: 4 10 6 10; -fx-background-color: #E8CC88;
                      -fx-background-radius: 0 0 6 6;
                      -fx-border-color: #C8A000 transparent transparent transparent;
                      -fx-border-width: 1;"/>
    </VBox>

    <!-- ══ CORNER ORNAMENTS ══ -->
    <Label text="✦" StackPane.alignment="TOP_LEFT" mouseTransparent="true"
           style="-fx-text-fill: #FFD700; -fx-font-size: 9; -fx-padding: 5 0 0 5;
                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.7), 2, 0, 0, 1);"/>
    <Label text="✦" StackPane.alignment="TOP_RIGHT" mouseTransparent="true"
           style="-fx-text-fill: #FFD700; -fx-font-size: 9; -fx-padding: 5 5 0 0;
                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.7), 2, 0, 0, 1);"/>
    <Label text="✦" StackPane.alignment="BOTTOM_LEFT" mouseTransparent="true"
           style="-fx-text-fill: #FFD700; -fx-font-size: 9; -fx-padding: 0 0 5 5;
                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.7), 2, 0, 0, 1);"/>
    <Label text="✦" StackPane.alignment="BOTTOM_RIGHT" mouseTransparent="true"
           style="-fx-text-fill: #FFD700; -fx-font-size: 9; -fx-padding: 0 5 5 0;
                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.7), 2, 0, 0, 1);"/>

</StackPane>
