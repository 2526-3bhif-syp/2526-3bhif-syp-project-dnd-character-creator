<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            style="-fx-background-color: #F5F5DC;">
    <top>
        <VBox alignment="CENTER" spacing="10">
            <BorderPane.margin><Insets top="20" bottom="20"/></BorderPane.margin>
            <Label text="Schritt 6: Gesinnung" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #8B0000;"/>
            <Label text="Wähle die Gesinnung deines Charakters." style="-fx-font-size: 16px; -fx-text-fill: #1A1A1A;"/>
        </VBox>
    </top>

    <center>
        <VBox fx:id="alignmentGrid" alignment="CENTER" spacing="20">
            <padding><Insets top="20" bottom="20" left="60" right="60"/></padding>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="50">
            <BorderPane.margin><Insets left="40" right="40" top="15" bottom="20"/></BorderPane.margin>
            <Button fx:id="btnBack" text="Zurück"
                    style="-fx-background-color: #F5F5DC; -fx-border-color: #C6A664; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10; -fx-text-fill: #1A1A1A; -fx-font-size: 18px;"
                    prefWidth="150" prefHeight="50"/>
            <Button fx:id="btnNext" text="Weiter"
                    style="-fx-background-color: #8B0000; -fx-text-fill: #F5F5DC; -fx-border-width: 0; -fx-background-radius: 10; -fx-font-size: 18px; -fx-font-weight: bold;"
                    prefWidth="150" prefHeight="50"/>
        </HBox>
    </bottom>
</BorderPane>