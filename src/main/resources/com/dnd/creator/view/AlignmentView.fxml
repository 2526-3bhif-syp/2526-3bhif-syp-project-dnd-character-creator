<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      styleClass="creation-root" spacing="0">

    <HBox fx:id="stepperContainer"/>

    <VBox alignment="CENTER" spacing="6">
        <padding><Insets top="4" bottom="14" left="40" right="40"/></padding>
        <Label text="Schritt 6 — Gesinnung" styleClass="section-title"/>
        <Label text="Wähle die moralische Ausrichtung deines Charakters." styleClass="section-subtitle"/>
    </VBox>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <padding><Insets left="40" right="40" top="0" bottom="10"/></padding>

        <VBox fx:id="alignmentGrid" alignment="CENTER" spacing="20" HBox.hgrow="ALWAYS"/>

        <VBox fx:id="previewContainer" spacing="8"/>
    </HBox>

    <HBox alignment="CENTER" spacing="40">
        <padding><Insets top="10" bottom="20" left="40" right="40"/></padding>
        <Button fx:id="btnBack" text="Zurück" styleClass="nav-button-back"/>
        <Button fx:id="btnNext" text="Weiter" styleClass="nav-button-next"/>
    </HBox>
</VBox>
