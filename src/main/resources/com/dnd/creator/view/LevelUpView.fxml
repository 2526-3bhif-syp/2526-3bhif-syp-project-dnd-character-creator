<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            style="-fx-background-color: radial-gradient(center 50% 38%, radius 90%, #FBF2D8, #E8D8A8);"
            prefWidth="820" prefHeight="720">
    <top>
        <VBox style="-fx-background-color: linear-gradient(to bottom, #FFF8E2, #F0E2B0); -fx-border-color: #C6A664; -fx-border-width: 0 0 3 0;">
            <Region prefHeight="3" style="-fx-background-color: linear-gradient(to right, transparent, #D4AF37, transparent);"/>
            <VBox alignment="CENTER" spacing="6">
                <padding>
                    <Insets top="18" bottom="14"/>
                </padding>
                <HBox alignment="CENTER" spacing="14">
                    <Label text="✦" style="-fx-font-size: 24px; -fx-text-fill: #D4AF37;"/>
                    <Label fx:id="lblTitle" text="LEVEL UP" style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-font-family: 'Serif'; -fx-text-fill: #6B0000; -fx-effect: dropshadow(gaussian, rgba(212,175,55,0.55), 8, 0, 0, 0);"/>
                    <Label text="✦" style="-fx-font-size: 24px; -fx-text-fill: #D4AF37;"/>
                </HBox>
                <Label fx:id="lblSubtitle" text="" style="-fx-font-size: 14px; -fx-text-fill: #5a3a1a; -fx-font-style: italic;"/>
            </VBox>
        </VBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox fx:id="contentBox" spacing="16">
            </VBox>
        </ScrollPane>
    </center>
    <bottom>
        <VBox style="-fx-background-color: linear-gradient(to top, #FFF8E2, #F0E2B0); -fx-border-color: #C6A664; -fx-border-width: 3 0 0 0;">
            <Region prefHeight="3" style="-fx-background-color: linear-gradient(to right, transparent, #D4AF37, transparent);"/>
            <HBox alignment="CENTER" spacing="22">
                <padding>
                    <Insets top="14" bottom="16" left="20" right="20"/>
                </padding>
                <Button fx:id="btnCancel" text="Abbrechen" style="-fx-background-color: #FFFBED; -fx-border-color: #C6A664; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10; -fx-text-fill: #6B4A1A; -fx-font-size: 14px; -fx-cursor: hand;" prefWidth="160" prefHeight="46"/>
                <Button fx:id="btnConfirm" text="✦ Level Up bestätigen" style="-fx-background-color: #2d5a3d; -fx-border-color: #1d3d28; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10; -fx-text-fill: #FFF8E2; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(45,90,61,0.5), 10, 0, 0, 0);" prefWidth="240" prefHeight="46"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>