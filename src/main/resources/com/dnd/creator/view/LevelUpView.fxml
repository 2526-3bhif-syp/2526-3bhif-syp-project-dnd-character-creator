<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      spacing="0" style="-fx-background-color: #F5F5DC;">

    <!-- Header -->
    <VBox style="-fx-background-color: #1A1A1A; -fx-padding: 16 24 14 24;" spacing="4">
        <Label text="LEVEL UP"
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #C6A664;"/>
        <Label fx:id="lblCharName"
               style="-fx-font-size: 14px; -fx-text-fill: #F5F5DC;"/>
        <Label fx:id="lblCurrentLevel"
               style="-fx-font-size: 12px; -fx-text-fill: #C6A664;"/>
    </VBox>

    <!-- Body -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent;">
        <VBox spacing="16">
            <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>

            <!-- Current classes -->
            <VBox spacing="8"
                  style="-fx-background-color: #FFFBF0; -fx-border-color: #C6A664; -fx-border-width: 1.5; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12;">
                <Label text="CURRENT CLASSES"
                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #8B0000;"/>
                <HBox fx:id="currentClassesBox" spacing="8" alignment="CENTER_LEFT"/>
            </VBox>

            <!-- Level up in existing class -->
            <VBox spacing="8">
                <Label text="Level up in existing class:"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;"/>
                <HBox fx:id="existingClassesBox" spacing="10" alignment="CENTER_LEFT"/>
            </VBox>

            <!-- Multiclass divider -->
            <HBox spacing="8" alignment="CENTER">
                <Region HBox.hgrow="ALWAYS"
                        style="-fx-background-color: #C6A664; -fx-min-height: 1; -fx-pref-height: 1; -fx-opacity: 0.6;"/>
                <Label text="MULTICLASSING"
                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #8B0000;"/>
                <Region HBox.hgrow="ALWAYS"
                        style="-fx-background-color: #C6A664; -fx-min-height: 1; -fx-pref-height: 1; -fx-opacity: 0.6;"/>
            </HBox>

            <!-- New class options -->
            <VBox spacing="8">
                <Label text="Add a new class (requires ability score prerequisites):"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;"/>
                <Label text="Grayed out classes do not meet the minimum score requirement."
                       style="-fx-font-size: 11px; -fx-text-fill: #666666;"/>
                <FlowPane fx:id="newClassesPane" hgap="8" vgap="8"/>
            </VBox>

            <!-- HP Preview -->
            <VBox fx:id="hpPreviewBox" spacing="4"
                  style="-fx-background-color: #FFFBF0; -fx-border-color: #C6A664; -fx-border-width: 1.5; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12;"
                  visible="false" managed="false">
                <Label text="HP INCREASE"
                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #8B0000;"/>
                <Label fx:id="lblHpPreview"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;"/>
                <Label fx:id="lblHpFormula"
                       style="-fx-font-size: 11px; -fx-text-fill: #666666;"/>
            </VBox>
        </VBox>
    </ScrollPane>

    <!-- Footer -->
    <HBox alignment="CENTER" spacing="16"
          style="-fx-border-color: #C6A664; -fx-border-width: 2 0 0 0; -fx-background-color: #F5F5DC;">
        <padding><Insets top="14" bottom="16" left="20" right="20"/></padding>
        <Button fx:id="btnCancel" text="Abbrechen"
                style="-fx-background-color: transparent; -fx-border-color: #C6A664; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #1A1A1A; -fx-font-size: 14px;"
                prefWidth="140" prefHeight="44"/>
        <Button fx:id="btnConfirm" text="Level Up bestätigen"
                style="-fx-background-color: #8B0000; -fx-text-fill: #F5F5DC; -fx-border-width: 0; -fx-background-radius: 8; -fx-font-size: 14px; -fx-font-weight: bold;"
                prefWidth="190" prefHeight="44" disable="true"/>
    </HBox>
</VBox>
