<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      styleClass="creation-root" spacing="0">

    <HBox fx:id="stepperContainer"/>

    <VBox alignment="CENTER" spacing="6">
        <padding><Insets top="4" bottom="14" left="40" right="40"/></padding>
        <Label text="Schritt 3 — Verteile deine Werte" styleClass="section-title"/>
        <Label text="Wähle für jeden Wert eine Zahl aus dem Pool. Dein Klassen-Hauptwert ist hervorgehoben." styleClass="section-subtitle"/>
    </VBox>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <padding><Insets left="40" right="40" top="0" bottom="10"/></padding>

        <!-- LEFT: stat rows -->
        <ScrollPane fitToWidth="true" HBox.hgrow="ALWAYS">
            <VBox fx:id="statsContainer" spacing="10">
                <padding><Insets top="4" bottom="14" left="2" right="2"/></padding>
            </VBox>
        </ScrollPane>

        <!-- RIGHT: preview + pool/actions -->
        <VBox spacing="14" minWidth="300" prefWidth="300" maxWidth="320">
            <VBox fx:id="previewContainer" spacing="8"/>

            <VBox spacing="10" styleClass="preview-panel">
                <Label text="Verfügbare Werte" styleClass="section-title" style="-fx-font-size: 14px;"/>
                <HBox fx:id="poolContainer" spacing="6"/>
                <Label text="Standard Array — sechs feste Zahlen für deine sechs Werte." styleClass="muted" wrapText="true"/>
                <HBox spacing="8">
                    <Button fx:id="btnAutoAssign" text="Auto-Vorschlag" styleClass="action-button"/>
                    <Button fx:id="btnReset" text="Zurücksetzen" styleClass="action-button"/>
                </HBox>
            </VBox>
        </VBox>
    </HBox>

    <HBox alignment="CENTER" spacing="40">
        <padding><Insets top="10" bottom="20" left="40" right="40"/></padding>
        <Button fx:id="btnBack" text="Zurück" styleClass="nav-button-back"/>
        <Button fx:id="btnNext" text="Weiter" styleClass="nav-button-next"/>
    </HBox>
</VBox>
