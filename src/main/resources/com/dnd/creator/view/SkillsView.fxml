<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      styleClass="creation-root" spacing="0">

    <HBox fx:id="stepperContainer"/>

    <VBox alignment="CENTER" spacing="6">
        <padding><Insets top="4" bottom="14" left="40" right="40"/></padding>
        <Label text="Schritt 4 — Hintergrund &amp; Fähigkeiten" styleClass="section-title"/>
        <Label text="Wähle, woher dein Held kommt — und worin er besonders gut ist." styleClass="section-subtitle"/>
    </VBox>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <padding><Insets left="40" right="40" top="0" bottom="10"/></padding>

        <!-- LEFT: backgrounds -->
        <VBox spacing="10" minWidth="280" prefWidth="300">
            <Label text="Hintergrund" styleClass="section-title" style="-fx-font-size: 14px;"/>
            <Label text="Wo dein Held herkommt — gibt zusätzliche Fähigkeiten." styleClass="muted"/>
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                <VBox fx:id="backgroundContainer" spacing="10">
                    <padding><Insets top="2" bottom="14" left="2" right="2"/></padding>
                </VBox>
            </ScrollPane>
        </VBox>

        <!-- MIDDLE: skills -->
        <VBox spacing="10" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Fähigkeiten" styleClass="section-title" style="-fx-font-size: 14px;"/>
                <Label fx:id="lblSkillsCounter" text="0 / 2 gewählt" styleClass="skill-counter"/>
            </HBox>
            <Label fx:id="lblSkillsHint" text="Wähle aus den verfügbaren Fähigkeiten deiner Klasse." styleClass="muted"/>
            <HBox fx:id="statsReminderBar" spacing="8" alignment="CENTER_LEFT"/>
            <!-- Live proficiency summary -->
            <VBox fx:id="proficiencyBox" spacing="4" styleClass="proficiency-summary-box">
                <padding><Insets top="6" bottom="6" left="10" right="10"/></padding>
                <Label text="Proficiencies deines Charakters:" styleClass="proficiency-summary-title"/>
                <FlowPane fx:id="proficiencyPane" hgap="6" vgap="4"/>
            </VBox>
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                <VBox fx:id="skillsContainer" spacing="10">
                    <padding><Insets top="2" bottom="14" left="2" right="2"/></padding>
                </VBox>
            </ScrollPane>
        </VBox>

        <!-- RIGHT: preview -->
        <VBox fx:id="previewContainer" spacing="8"/>
    </HBox>

    <HBox alignment="CENTER" spacing="40">
        <padding><Insets top="10" bottom="20" left="40" right="40"/></padding>
        <Button fx:id="btnBack" text="Zurück" styleClass="nav-button-back"/>
        <Button fx:id="btnNext" text="Weiter" styleClass="nav-button-next"/>
    </HBox>
</VBox>
