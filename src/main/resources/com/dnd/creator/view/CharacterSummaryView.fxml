<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" style="-fx-background-color: #F5F5DC;">
    <!-- Top: Header -->
    <top>
        <VBox alignment="CENTER" spacing="10">
            <BorderPane.margin>
                <Insets top="20" bottom="20"/>
            </BorderPane.margin>
            <Label text="Schritt 6: Charakter-Zusammenfassung" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #8B0000;"/>
            <Label text="Überprüfe deinen Charakter und speichere ihn." style="-fx-font-size: 16px; -fx-text-fill: #1A1A1A;"/>
        </VBox>
    </top>

    <!-- Center: Character Summary -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: #F5F5DC; -fx-background-color: #F5F5DC;">
            <VBox alignment="CENTER_LEFT" spacing="20">
                <padding>
                    <Insets top="20" bottom="20" left="40" right="40"/>
                </padding>

                <!-- Character Name -->
                <VBox spacing="5">
                    <Label text="Charaktername:" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #8B0000;"/>
                    <Label fx:id="lblCharacterName" text="[Name]" style="-fx-font-size: 16px; -fx-text-fill: #1A1A1A;"/>
                </VBox>

                <!-- Class & Race -->
                <HBox spacing="40">
                    <VBox spacing="5">
                        <Label text="Klasse:" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #8B0000;"/>
                        <Label fx:id="lblClass" text="[Klasse]" style="-fx-font-size: 16px; -fx-text-fill: #1A1A1A;"/>
                    </VBox>
                    <VBox spacing="5">
                        <Label text="Rasse:" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #8B0000;"/>
                        <Label fx:id="lblRace" text="[Rasse]" style="-fx-font-size: 16px; -fx-text-fill: #1A1A1A;"/>
                    </VBox>
                </HBox>

                <!-- Ability Scores -->
                <VBox spacing="10">
                    <Label text="Attributswerte:" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #8B0000;"/>
                    <VBox fx:id="abilityScoresContainer" spacing="5">
                        <!-- Ability scores will be added dynamically -->
                    </VBox>
                </VBox>

                <!-- Background -->
                <VBox spacing="5">
                    <Label text="Hintergrund:" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #8B0000;"/>
                    <Label fx:id="lblBackground" text="[Hintergrund]" style="-fx-font-size: 16px; -fx-text-fill: #1A1A1A;"/>
                </VBox>

                <!-- Skills -->
                <VBox spacing="5">
                    <Label text="Fertigkeiten:" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #8B0000;"/>
                    <Label fx:id="lblSkills" text="[Fertigkeiten]" style="-fx-font-size: 16px; -fx-text-fill: #1A1A1A;"/>
                </VBox>

                <!-- Equipment -->
                <VBox spacing="5">
                    <Label text="Ausrüstung:" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #8B0000;"/>
                    <Label fx:id="lblEquipment" text="[Ausrüstung]" style="-fx-font-size: 16px; -fx-text-fill: #1A1A1A;"/>
                </VBox>

                <!-- Spells -->
                <VBox spacing="5">
                    <Label text="Zauber:" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #8B0000;"/>
                    <Label fx:id="lblSpells" text="[Zauber]" style="-fx-font-size: 16px; -fx-text-fill: #1A1A1A;"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

    <!-- Bottom: Action Buttons -->
    <bottom>
        <VBox spacing="20">
            <BorderPane.margin>
                <Insets left="40" right="40" top="10" bottom="20"/>
            </BorderPane.margin>

            <HBox alignment="CENTER" spacing="50">
                <Button fx:id="btnBack" text="Zurück" style="-fx-background-color: #F5F5DC; -fx-border-color: #C6A664; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10; -fx-text-fill: #1A1A1A; -fx-font-size: 18px;" prefWidth="150" prefHeight="50"/>
                <Button fx:id="btnSave" text="Speichern" style="-fx-background-color: #8B0000; -fx-text-fill: #F5F5DC; -fx-border-width: 0; -fx-background-radius: 10; -fx-font-size: 18px; -fx-font-weight: bold;" prefWidth="150" prefHeight="50"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
