<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      styleClass="creation-root" spacing="0">

    <HBox fx:id="stepperContainer"/>

    <VBox alignment="CENTER" spacing="6">
        <padding><Insets top="4" bottom="14" left="40" right="40"/></padding>
        <Label text="Schritt 2 — Welche Klasse passt zu dir?" styleClass="section-title"/>
        <Label text="Die Klasse bestimmt deinen Spielstil im Kampf." styleClass="section-subtitle"/>
    </VBox>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <padding><Insets left="40" right="40" top="0" bottom="10"/></padding>

        <VBox spacing="12" HBox.hgrow="ALWAYS">
            <HBox fx:id="filterBar" spacing="8"/>
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                <TilePane fx:id="classGrid" hgap="14" vgap="14" prefColumns="4"
                          prefTileWidth="220" prefTileHeight="180">
                    <padding><Insets top="4" bottom="14" left="2" right="2"/></padding>
                </TilePane>
            </ScrollPane>
            <VBox styleClass="difficulty-legend-box" spacing="6">
                <padding><Insets top="8" bottom="8" left="12" right="12"/></padding>
                <Label text="Schwierigkeit" styleClass="difficulty-legend-heading"/>
                <Label text="★☆☆  —  Einfach  —  Gut für Einsteiger" styleClass="difficulty-legend-row"/>
                <Label text="★★☆  —  Mittel  —  Etwas Erfahrung von Vorteil" styleClass="difficulty-legend-row"/>
                <Label text="★★★  —  Komplex  —  Viele Regeln zu lernen" styleClass="difficulty-legend-row"/>
            </VBox>
        </VBox>

        <VBox fx:id="previewContainer" spacing="8"/>
    </HBox>

    <HBox alignment="CENTER" spacing="40">
        <padding><Insets top="6" bottom="20" left="40" right="40"/></padding>
        <Button fx:id="btnBack" text="Zurück" styleClass="nav-button-back"/>
        <Button fx:id="btnNext" text="Weiter" styleClass="nav-button-next"/>
    </HBox>
</VBox>
