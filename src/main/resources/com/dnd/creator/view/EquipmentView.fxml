<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      styleClass="creation-root" spacing="0">

    <HBox fx:id="stepperContainer"/>

    <VBox alignment="CENTER" spacing="6">
        <padding><Insets top="4" bottom="14" left="40" right="40"/></padding>
        <Label text="Schritt 5 — Wähle deine Ausrüstung" styleClass="section-title"/>
        <Label text="Pflicht-Ausrüstung bekommst du automatisch. Bei den Wahl-Bündeln klick auf das, was du nehmen willst." styleClass="section-subtitle"/>
    </VBox>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <padding><Insets left="40" right="40" top="0" bottom="10"/></padding>

        <ScrollPane fitToWidth="true" HBox.hgrow="ALWAYS">
            <VBox spacing="18">
                <padding><Insets top="2" bottom="14" left="2" right="2"/></padding>

                <VBox spacing="8">
                    <Label text="Pflicht-Ausrüstung" styleClass="choice-block-title"/>
                    <VBox fx:id="mandatoryContainer" spacing="6" styleClass="mandatory-list"/>
                </VBox>

                <VBox fx:id="choicesContainer" spacing="14"/>
            </VBox>
        </ScrollPane>

        <VBox fx:id="previewContainer" spacing="8"/>
    </HBox>

    <HBox alignment="CENTER" spacing="40">
        <padding><Insets top="10" bottom="20" left="40" right="40"/></padding>
        <Button fx:id="btnBack" text="Zurück" styleClass="nav-button-back"/>
        <Button fx:id="btnNext" text="Weiter" styleClass="nav-button-next"/>
    </HBox>
</VBox>
