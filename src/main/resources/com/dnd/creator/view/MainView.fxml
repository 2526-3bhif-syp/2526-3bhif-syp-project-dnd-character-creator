<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            style="-fx-background-color: radial-gradient(center 50% 38%, radius 90%, #FBF2D8, #E8D8A8);">
    <top>
        <VBox alignment="CENTER" spacing="6">
            <BorderPane.margin>
                <Insets top="40" bottom="10"/>
            </BorderPane.margin>
            <Label text="⚔" style="-fx-font-size: 56px; -fx-text-fill: #6B0000; -fx-effect: dropshadow(gaussian, rgba(212,175,55,0.6), 12, 0, 0, 0);"/>
            <Label text="DnD Character Creator"
                   style="-fx-font-size: 44px; -fx-font-weight: bold; -fx-font-family: 'Serif'; -fx-text-fill: #6B0000; -fx-effect: dropshadow(gaussian, rgba(212,175,55,0.65), 10, 0, 0, 0);"/>
            <Label text="✦ forge your legend ✦"
                   style="-fx-font-size: 16px; -fx-font-style: italic; -fx-text-fill: #8A6A20;"/>
        </VBox>
    </top>
    <center>
        <VBox alignment="CENTER" spacing="26">
            <Button fx:id="btnCreate" onAction="#handleCreate" text="✦  Create  ✦"
                    style="-fx-background-color: linear-gradient(to bottom, #FFFBED, #F5E8C2); -fx-border-color: #D4AF37 #8A6A20 #8A6A20 #D4AF37; -fx-border-radius: 12; -fx-background-radius: 12; -fx-text-fill: #6B0000; -fx-border-width: 3; -fx-font-size: 24px; -fx-font-family: 'Serif'; -fx-font-weight: bold; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(60,40,10,0.3), 10, 0, 0, 4);"
                    prefWidth="320" prefHeight="70"/>
            <Button onAction="#handleShowOverview" text="✦  Deck  ✦"
                    style="-fx-background-color: linear-gradient(to bottom, #FFFBED, #F5E8C2); -fx-border-color: #D4AF37 #8A6A20 #8A6A20 #D4AF37; -fx-border-radius: 12; -fx-background-radius: 12; -fx-text-fill: #6B0000; -fx-border-width: 3; -fx-font-size: 24px; -fx-font-family: 'Serif'; -fx-font-weight: bold; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(60,40,10,0.3), 10, 0, 0, 4);"
                    prefWidth="320" prefHeight="70"/>
            <Button text="✦  Rules  ✦"
                    style="-fx-background-color: linear-gradient(to bottom, #FFFBED, #F5E8C2); -fx-border-color: #D4AF37 #8A6A20 #8A6A20 #D4AF37; -fx-border-radius: 12; -fx-background-radius: 12; -fx-text-fill: #6B0000; -fx-border-width: 3; -fx-font-size: 24px; -fx-font-family: 'Serif'; -fx-font-weight: bold; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(60,40,10,0.3), 10, 0, 0, 4);"
                    prefWidth="320" prefHeight="70"/>
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER">
            <BorderPane.margin>
                <Insets bottom="14"/>
            </BorderPane.margin>
            <Label text="v1.0  ·  a tabletop codex"
                   style="-fx-font-size: 11px; -fx-text-fill: #8B7355; -fx-font-style: italic;"/>
        </HBox>
    </bottom>
</BorderPane>
