<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            style="-fx-background-color: #FBF2D8;">

    <!-- Header -->
    <top>
        <HBox style="-fx-background-color: #FFF8E2; -fx-border-color: #C6A664; -fx-border-width: 0 0 2 0; -fx-padding: 12 20 10 20;"
              spacing="16" alignment="CENTER_LEFT">

            <!-- Portrait -->
            <StackPane fx:id="portraitPane"
                       style="-fx-background-color: #F5EBD0; -fx-border-color: #D4AF37 #8A6A20 #8A6A20 #D4AF37; -fx-border-width: 2; -fx-background-radius: 6; -fx-border-radius: 6;"
                       minWidth="90" minHeight="110" maxWidth="90" maxHeight="110">
                <ImageView fx:id="imgPortrait" fitWidth="86" fitHeight="106" preserveRatio="true"/>
            </StackPane>

            <!-- Name + fields -->
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label fx:id="lblCharacterName" text="CHARACTER NAME"
                       style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-font-family: 'Serif'; -fx-text-fill: #6B0000; -fx-effect: dropshadow(gaussian, rgba(212,175,55,0.5), 6, 0, 0, 0);"/>
                <HBox spacing="30">
                    <VBox>
                        <Label fx:id="lblClassLevel" text="Class | Level"
                               style="-fx-font-size: 14px; -fx-text-fill: #3A2410;"/>
                        <Label text="CLASS &amp; LEVEL"
                               style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #8B7355;"/>
                    </VBox>
                    <VBox>
                        <Label fx:id="lblBackground" text="Background"
                               style="-fx-font-size: 14px; -fx-text-fill: #3A2410;"/>
                        <Label text="BACKGROUND"
                               style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #8B7355;"/>
                    </VBox>
                    <VBox>
                        <Label fx:id="lblRace" text="Race"
                               style="-fx-font-size: 14px; -fx-text-fill: #3A2410;"/>
                        <Label text="RACE"
                               style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #8B7355;"/>
                    </VBox>
                </HBox>
            </VBox>
        </HBox>
    </top>

    <!-- 3-Column Sheet -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="false"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <HBox spacing="12" alignment="TOP_CENTER">
                <padding>
                    <Insets top="10" bottom="10" left="12" right="12"/>
                </padding>

                <VBox fx:id="leftColumn" spacing="7" HBox.hgrow="SOMETIMES"
                      style="-fx-background-color: #FFFBED; -fx-border-color: #C6A664; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8;"/>

                <VBox fx:id="middleColumn" spacing="7" HBox.hgrow="SOMETIMES"
                      style="-fx-background-color: #FFFBED; -fx-border-color: #C6A664; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8;"/>

                <VBox fx:id="rightColumn" spacing="7" HBox.hgrow="SOMETIMES"
                      style="-fx-background-color: #FFFBED; -fx-border-color: #C6A664; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8;"/>
            </HBox>
        </ScrollPane>
    </center>

    <!-- Footer Buttons -->
    <bottom>
        <HBox alignment="CENTER" spacing="20" style="-fx-background-color: #FFF8E2; -fx-border-color: #C6A664; -fx-border-width: 2 0 0 0;">
            <padding>
                <Insets top="12" bottom="16" left="20" right="20"/>
            </padding>
            <Button fx:id="btnDelete" text="Delete"
                    style="-fx-background-color: #FFF8E2; -fx-border-color: #8B0000; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #8B0000; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;"
                    prefWidth="130" prefHeight="44"/>
            <Button fx:id="btnEdit" text="Edit"
                    style="-fx-background-color: #FFF8E2; -fx-border-color: #D4AF37; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #6B0000; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;"
                    prefWidth="130" prefHeight="44"/>
            <Button fx:id="btnClose" text="Close"
                    style="-fx-background-color: #FFFBED; -fx-border-color: #C6A664; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #6B4A1A; -fx-font-size: 14px; -fx-cursor: hand;"
                    prefWidth="130" prefHeight="44"/>
        </HBox>
    </bottom>
</BorderPane>
